{
  "schema_version": "route-pack-v1",
  "id": "gws_schedule",
  "bucket": "trigger",
  "summary": "수업 일정 관리는 구글 캘린더 gws CLI로 (조회 후 등록)",
  "required_tokens": ["일정"],
  "first_command": "python -m chat_lms_agent gws status --json",
  "then_command": "python -m chat_lms_agent gws calendar create-event --title <t> --start <iso> --end <iso> --json",
  "fallback_command": "python -m chat_lms_agent gws setup --json",
  "must_not": [
    "do not automate a browser for calendar work; use the gws CLI"
  ],
  "time_budget_ms": 5000
}
